#!/bin/bash

STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
HOME_MANAGER_DIR=~/.config/home-manager

case "$1" in
  list)
    nix path-info -r --json --json-format 2 "$(readlink -f "$STATE_HOME"/nix/profiles/home-manager)" | \
    jq -r '
      .info | to_entries | map(.value + {path: .key}) | .[] |
      . + (.path | sub("^[a-z0-9]{32}-"; "") | capture("^(?<name>.*)-(?=[0-9])(?<ver>.*)$")) |
      "\(.name)|\(.ver)|\(.narSize)"
    ' | \
    awk -F '|' '{printf "%-45s %-20s %10.2f MB\n", $1, $2, $3/1024/1024}' | \
    sort
    ;;

  update)
    nix flake update --flake $HOME_MANAGER_DIR
    echo -n "Do you want 'chezmoi re-add flake.lock'? [Y/n] "
    read -r res

    if [[ -z "$res" || "$res" =~ ^[yY]$ ]]; then
      chezmoi re-add $HOME_MANAGER_DIR/flake.lock
    fi
    ;;

  *)
    echo "Usage: hm {list|update}"
    exit 1
    ;;
esac
