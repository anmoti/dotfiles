# https://wiki.hypr.land/Configuring/Variables/#input
input {
    kb_layout = jp
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    numlock_by_default = true

    follow_mouse = 1

    sensitivity = 0 # -1.0 - 1.0, 0 means no modification.

    touchpad {
        natural_scroll = true
    }
}

# Example per-device config
# See https://wiki.hypr.land/Configuring/Keywords/#per-device-input-configs for more
#device {
#    name = razer-razer-viper-ultimate
#    sensitivity = -0.5
#}

# See https://wiki.hypr.land/Configuring/Keywords/

$MOD  = SUPER
$MODS = $MOD SHIFT
$MODC = $MOD CTRL

$LMB = mouse:272
$RMB = mouse:273

{{- $dirs := list "left" "right" "up" "down" -}}

# Example binds, see https://wiki.hypr.land/Configuring/Binds/ for more
# See https://wiki.hypr.land/Configuring/Gestures

bindd  = $MOD , Return      , Open Terminal           , exec, $terminal
bindd  = $MOD , Space       , Open Quick Launcher     , exec, $menu
bindd  = $MOD , E           , Open File Manager       , exec, $fileManager
bindd  = $MOD , O           , Open Browser            , exec, $browser

bindd  = $MOD , L           , Lock Screen             , exec, $lock

bindd  = $MODS, C           , Use Color picker        , exec, hyprpicker --autocopy --format=hex
bindd =       , Print       , Take Screenshot         , exec, ~/.config/hypr/scripts/screenshot_satty.sh

bindd  = $MOD , F           , Toggle Window Floating  , togglefloating,
bindd  = $MOD , Q           , Close Window            , killactive,

bindd  = $MOD , P           , Toggle Pseudo           , pseudo,
bindd  = $MOD , J           , Toggle Split            , togglesplit,

$msg = Move Focus:
{{- range $dirs }}
bindd  = $MOD , {{ printf "%-12s, $msg %-8s           , movefocus, %s" . (title .) . }}
{{- end }}

$msg = Move Window:
{{- range $dirs }}
bindd  = $MODS, {{ printf "%-12s, $msg %-8s           , movewindow, %s" . (title .) . }}
{{- end }}
{{- range untilStep 1 11 1 }}
bindd  = $MODS, {{ printf "%-12d, $msg %2d%8s         , movetoworkspace, %d" (mod . 10) . "" . }}
{{- end }}
bindd  = $MODS, mouse_up    , $msg Next (Mouse)       , movetoworkspace, +1
bindd  = $MODS, mouse_down  , $msg Prev (Mouse)       , movetoworkspace, -1
binddm = $MOD , $LMB        , $msg (Mouse)            , movewindow
bindd  = $MODS, S           , $msg Special(magic)     , movetoworkspace, special:magic

$msg = Resize Window:
bindde = $MODC, left        , $msg Shrink Width       , resizeactive, -10   0
bindde = $MODC, right       , $msg Expand Width       , resizeactive,  10   0
bindde = $MODC, up          , $msg Shrink Height      , resizeactive,   0 -10
bindde = $MODC, down        , $msg Expand Height      , resizeactive,   0  10
binddm = $MOD , $RMB        , $msg (Mouse)            , resizewindow

$msg = Switch Workspace:
{{- range untilStep 1 11 1 }}
bindd  = $MOD , {{ printf "%-12d, $msg %2d%8s         , workspace, %d" (mod . 10) . "" . }}
{{- end }}
bindd  = $MOD , mouse_up    , $msg Next (Mouse)       , workspace, +1
bindd  = $MOD , mouse_down  , $msg Prev (Mouse)       , workspace, -1
bindd  = $MOD , S           , $msg Special(magic)     , togglespecialworkspace, magic

gesture = 3, horizontal, workspace

bindd  = $MODS, R           , Reload Config           , exec, hyprctl reload
bindd  = $MODS, M           , Exit Hyprland           , exit,

# Requires Wireplumber
bindel = , XF86AudioRaiseVolume   , exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ --limit 1.0
bindel = , XF86AudioLowerVolume   , exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

bindl  = , XF86AudioMute          , exec, wpctl set-mute @DEFAULT_AUDIO_SINK@   toggle
bindl  = , XF86AudioMicMute       , exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Requires playerctl
bindl  = , XF86AudioNext          , exec, playerctl next
bindl  = , XF86AudioPause         , exec, playerctl play-pause
bindl  = , XF86AudioPlay          , exec, playerctl play-pause
bindl  = , XF86AudioPrev          , exec, playerctl previous

# Requires brightnessctl
bindel = , XF86MonBrightnessUp    , exec, ~/.local/bin/change-brightness set +5
bindel = , XF86MonBrightnessDown  , exec, ~/.local/bin/change-brightness set -5

